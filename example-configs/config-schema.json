{
  "schema": {
    "example": {
      "connection": {
        "database": "PgVectorConnectionProvider",
        "parameters": {
          "host": "10.34.64.127",
          "port": "5432",
          "username": "postgres",
          "password": "vitrivr"
        }
      },
      "fields": {
        "averagecolor": {
          "factory": "AverageColor"
        },
        "file": {
          "factory": "FileSourceMetadata"
        },
        "clip": {
          "factory": "CLIP",
          "parameters": {
            "host": "http://10.34.64.208:8888/",
            "limit": "1"
          }
        },
        "time": {
          "factory": "TemporalMetadata"
        },
        "video": {
          "factory": "VideoSourceMetadata"
        }
      },
      "resolvers": {
        "thumbnails": {
          "factory": "DiskResolver",
          "parameters": {
            "location": "/path/to/thumbnails"
          }
        }
      },
      "exporters": {
        "thumbnail": {
          "factory": "ThumbnailExporter",
          "parameters": {
            "resolver": "thumbnails",
            "maxSideResolution": "500",
            "mimeType": "JPG"
          }
        }
      },
      "extractionPipelines": {
        "img": {
          "path": "./example-configs/image-ingest.json"
        },
        "vid": {
          "path": "./example-configs/video-ingest.json"
        }
      }
    }
  }
}