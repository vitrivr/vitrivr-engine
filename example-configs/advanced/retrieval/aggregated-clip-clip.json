{
  "inputs": {
    "txt-1": {"type": "TEXT", "data": "A diver"},
    "txt-2": {"type": "TEXT", "data": "A catfish"}
  },
  "operations": {
    "clip":       {"field": "clip", "inputs":{"txt":"txt-1"}, "parameters": {"limit": "100"}},
    "clip-2":       {"field": "clip", "inputs":{"txt":"txt-2"}},
    "relations":  {"factory": "RelationExpander", "inputs":{"in": "clip"}, "parameters": {"outgoing": "partOf"}},
    "relations-2":  {"factory": "RelationExpander", "inputs":{"in": "clip-2"}, "parameters": {"outgoing": "partOf"}},
    "aggregator": {"factory": "ScoreAggregator", "inputs":{"in": "relations"}},
    "aggregator-2": {"factory": "ScoreAggregator", "inputs":{"in": "relations-2"}},
    "fusion": {"factory": "WeightedScoreFusion", "inputs":{"in": "aggregator", "in-2": "aggregator-2"}, "parameters": {"weights": "0.7 , 0.3", "p": "2", "normalize": "true"}},
    "timelookup": {"factory": "FieldLookup",  "inputs": {"in":"fusion"}, "parameters": {"field": "time", "keys": "start, end"}},
    "filelookup": {"factory": "ObjectFieldLookup",  "inputs": {"in":"timelookup"}, "parameters": {"field": "file", "predicates": "partOf", "keys": "path"}}
  },
  "output": "filelookup"
}