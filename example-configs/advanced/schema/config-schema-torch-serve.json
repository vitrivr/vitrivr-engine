{
  "schema": {
    "example": {
      "connection": {
        "database": "PgVectorConnectionProvider",
        "parameters": {
          "host": "10.34.64.127",
          "port": "5432",
          "username": "postgres",
          "password": "vitrivr"
        }
      },
      "fields": {
        "averagecolor": {
          "factory": "AverageColor"
        },
        "file": {
          "factory": "FileSourceMetadata"
        },
        "clip": {
          "factory": "TSEmbedding",
          "parameters": {
            "host": "127.0.0.1",
            "port": "8080",
            "model": "clip_model",
            "dimension": "512"
          }
        },
        "dino": {
          "factory": "TSEmbedding",
          "parameters": {
            "host": "127.0.0.1",
            "port": "8080",
            "model": "dino_model ",
            "dimension": "384"
          }
        },
        "time": {
          "factory": "TemporalMetadata"
        },
        "video": {
          "factory": "VideoSourceMetadata"
        }
      },
      "resolvers": {
        "thumbnails": {
          "factory": "DiskResolver",
          "parameters": {
            "location": "/path/to/thumbnails"
          }
        }
      },
      "exporters": {
        "thumbnail": {
          "factory": "ThumbnailExporter",
          "parameters": {
            "resolver": "thumbnails",
            "maxSideResolution": "500",
            "mimeType": "JPG"
          }
        }
      },
      "extractionPipelines": {
        "img": {
          "path": "./PATH/TO/image-ingest-torch-serve.json"
        },
        "vid": {
          "path": "./PATH/TO/video-ingest-torch-serve.json"
        }
      }
    }
  }
}