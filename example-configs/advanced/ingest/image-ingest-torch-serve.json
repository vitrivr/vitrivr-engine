{
  "schema": "example",
  "context": {
    "contentFactory": "InMemoryContentFactory",
    "resolvers":["thumbnails"]
  },
  "operators": {
    "enumerator": {
      "factory": "FileSystemEnumerator",
      "parameters": {
        "path": "/path/to/images",
        "depth": "3",
        "mediaTypes": "IMAGE"
      }
    },
    "decoder": {
      "factory": "VideoDecoder",
      "parameters": {
        "timeWindowMs": "1000"
      }
    },
    "metadata":{
      "field": "video"
    },
    "source":{
      "field": "file"
    },
    "aggregator": {
      "factory": "MiddleContentAggregator"
    },
    "persister": {
      "factory": "PersistRetrievableTransformer"
    },
    "time": {
      "field": "time"
    },
    "averagecolor": {
      "field": "averagecolor"
    },
    "clip": {
      "field": "clip"
    },
    "dino": {
      "field": "dino"
    },
    "thumbnail": {
      "exporter": "thumbnail"
    },
    "filter": {
      "factory": "TypeFilterTransformer",
      "parameters": {
        "type": "SOURCE:VIDEO"
      }
    }
  },
  "operations": {
    "enumerator": {"operator": "enumerator"},
    "decoder": {"operator": "decoder", "inputs": ["enumerator"]},
    "persist": {"operator": "persister", "inputs": ["middle"]},
    "metadata": {"operator": "metadata", "inputs": ["persist"]},
    "source": {"operator": "source", "inputs": ["persist"]},
    "averagecolor": {"operator": "averagecolor", "inputs": ["persist"]},
    "clip": {"operator": "clip", "inputs": ["persist"]},
    "dino": {"operator": "dino", "inputs": ["persist"]},
    "thumbnail": {"operator": "thumbnail", "inputs": ["persist"]}
  },
  "output": [
    "metadata",
    "source",
    "averagecolor",
    "thumbnail",
    "time",
    "clip",
    "dino",
    "thumbnail"
  ],
  "mergeType": "MERGE"
}